rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /screencast/liveFrame {
      // Allow authenticated anonymous users (pc/client) to share and view frames.
      allow read, write: if request.auth != null;
    }

    // Deny all other document paths by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
